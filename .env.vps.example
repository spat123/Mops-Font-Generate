# Скопируйте на VPS как .env.production (рядом с docker-compose.prod.yml)
# chmod 600 .env.production

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

NEXTAUTH_URL=https://dynamicfont.ru
NEXTAUTH_SECRET=
NEXT_PUBLIC_SITE_URL=https://dynamicfont.ru

# Neon или Postgres на VPS / REG Cloud DB
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/dinamic_font?sslmode=require
# Для Neon оставьте URL как есть; для VPS Postgres: DATABASE_DRIVER=postgres

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

RESEND_API_KEY=
EMAIL_FROM=DINAMIC FONT <noreply@dynamicfont.ru>

# FONTTOOLS_PYTHON задаётся в Dockerfile (/usr/bin/python3)
