{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "checkJs": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "maxNodeModuleJsDepth": 0,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "components/**/*.jsx",
    "constants/**/*.js",
    "lib/**/*.js"
  ],
  "exclude": ["node_modules", "__tests__", "**/*.ts", "**/*.tsx"]
}
