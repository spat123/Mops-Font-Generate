# Скопируйте в Yandex Cloud (Serverless Container / VM) как переменные окружения.
# Global-версия остаётся на Vercel с другим набором secrets.

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Обязательно для RU
NEXTAUTH_URL=https://dynamicfont.ru
NEXTAUTH_SECRET=
NEXT_PUBLIC_SITE_URL=https://dynamicfont.ru

# Yandex Managed PostgreSQL (НЕ Neon URL)
DATABASE_URL=postgresql://USER:PASSWORD@c-xxxxx.rw.mdb.yandexcloud.net:6432/dinamic_font?sslmode=require
# DATABASE_DRIVER=postgres

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Почта: Resend или SMTP (для РФ лучше свой SMTP на домене)
RESEND_API_KEY=
EMAIL_FROM=DINAMIC FONT <noreply@dynamicfont.ru>

# Опционально
# AUTH_CREDENTIALS_LOGIN=
# AUTH_CREDENTIALS_PASSWORD=
# LOGIN_STEP_UP_DISABLED=0
