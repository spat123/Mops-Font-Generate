# NextAuth: https://next-auth.js.org/configuration/options
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
# Абсолютные URL для Open Graph (превью ссылок). На проде: https://dynamicfont.ru
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Демо-вход по логину/паролю (опционально)
# Если заданы оба значения, на странице /auth/signin появится рабочий вход через Credentials.
AUTH_CREDENTIALS_LOGIN=
AUTH_CREDENTIALS_PASSWORD=

# (устарело) MIN_OAUTH_ACCOUNT_AGE_DAYS — не используется: Google не отдаёт дату создания аккаунта.

# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Яндекс OAuth: https://oauth.yandex.ru/client/new
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Регистрация email/пароль + подтверждение почты (Resend): https://resend.com
RESEND_API_KEY=
# На free без своего домена: onboarding@resend.dev (см. Resend → Domains)
EMAIL_FROM=DINAMIC FONT <onboarding@resend.dev>

# Вход с нового устройства: код на email (нужен DATABASE_URL). Локально без кода: LOGIN_STEP_UP_DISABLED=1
# LOGIN_STEP_UP_DISABLED=1

# Юридические страницы /legal/* (ФИО самозанятого, контакты)
# LEGAL_OPERATOR_FULL_NAME=Мочалов Игорь Сергеевич
# LEGAL_OPERATOR_INN=
# LEGAL_SUPPORT_EMAIL=support@dynamicfont.ru
# LEGAL_PRIVACY_EMAIL=privacy@dynamicfont.ru

# Пользователи: локально — data/users.json; на Vercel / Yandex RU — Postgres
# Neon (global Vercel): https://neon.tech
# Yandex Managed PostgreSQL (RU): sslmode=require в URL
# DATABASE_DRIVER=neon | postgres — принудительно (по умолчанию: neon.tech в URL → neon, иначе postgres)
DATABASE_URL=

# --- Только при npm run dev (NODE_ENV=development) ---
# Симуляция Pro для проверки UI (все залогиненные пользователи).
# DEV_PRO_SIMULATION=1
#
# Или Pro только для указанных email (через запятую / пробел / точка с запятой):
# DEV_PRO_EMAILS=you@example.com,qa@example.com
#
# Или Pro по id пользователя из data/users.json:
# DEV_PRO_USER_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Генерация статических шрифтов (Pyodide / ONREZA, Bun) ---
# Путь к Node.js, если основной процесс — Bun (ONREZA COMPUTE): /usr/bin/node
# FONT_GEN_NODE_PATH=
# Принудительно всегда использовать Node-worker для @web-alchemy/fonttools
# FONT_GEN_FORCE_NODE_WORKER=1
# Таймаут worker (мс), по умолчанию 120000
# FONT_GEN_TIMEOUT_MS=120000
