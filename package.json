{
  "name": "dinamic-font",
  "version": "1.0.2",
  "description": "DINAMIC FONT — веб-приложение для проверки, создания и анимации шрифтов",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/copy-standalone-font-gen.mjs",
    "start": "node scripts/start-standalone.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "typecheck:js": "tsc --noEmit -p jsconfig.json",
    "format": "prettier --write .",
    "myskotom:gap": "bun run scripts/build-myskotom-gap-list.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "@fontsource/montserrat": "^5.2.5",
    "@fontsource/open-sans": "^5.2.5",
    "@fontsource/poppins": "^5.2.5",
    "@fontsource/roboto": "^5.2.5",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/postcss": "^4.0.17",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@web-alchemy/fonttools": "^1.4.0",
    "baseline-browser-mapping": "^2.10.32",
    "caniuse-lite": "^1.0.30001793",
    "jose": "^4.15.9",
    "lightningcss": "^1.30.1",
    "lottie-web": "^5.13.0",
    "next": "^14.1.0",
    "next-auth": "^4.24.11",
    "opentype.js": "^1.3.4",
    "postgres": "^3.4.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-toastify": "^11.0.5",
    "resend": "^6.12.3",
    "woff2-encoder": "^2.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.2.15",
    "autoprefixer": "^10.4.21",
    "jest": "^30.4.2",
    "postcss": "^8.4.31",
    "tailwindcss": "^4.0.14",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
